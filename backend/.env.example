# Backend Environment Variables (Local Development)
# For production (Render), set these in the Render Dashboard.

# Strictly matched CORS origins (comma-separated for multiple)
# Example: https://standardpumps.vercel.app,https://www.standardpumps.com
FRONTEND_URL=https://standard-pumps.vercel.app/


# Strictly matched Host headers to prevent DNS rebinding attacks (comma-separated)
# Example: spqs-backend.onrender.com,api.standardpumps.com
ALLOWED_HOSTS=standard-pumps-quotation-system.onrender.com,localhost,127.0.0.1
# SQLite Database path. In production on Render, point this to the persistent disk.
# Example: sqlite:////data/standard_pumps.db
DATABASE_URL=sqlite:///./standard_pumps.db

# Deployment environment (development, staging, production)
ENVIRONMENT=production
